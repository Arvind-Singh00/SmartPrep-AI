# Copy this file to .env and fill real values. DO NOT commit .env

# MongoDB connection string
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/dbname

# JWT secret for authentication
JWT_SECRET=your_jwt_secret

# Port the server listens on (Render sets PORT automatically)
PORT=5000

# Node environment
NODE_ENV=production

# Any API keys (example: OpenAI / Google GenAI)
OPENAI_API_KEY=your_openai_api_key
# Server
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=your_mongodb_atlas_connection_string

# JWT
JWT_SECRET=your_jwt_secret_min_64_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key

# ChromaDB
CHROMA_SERVER_URL=http://localhost:8000

# Upload
MAX_UPLOAD_SIZE_MB=10

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQS=100
